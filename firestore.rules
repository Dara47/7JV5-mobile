rules_version = '2';

// ============================================================================
// Firestore Rules — 7J Eng Mobile V5.1  (PROD: jenglishcenter-v4)
// เฟส 2 — 2026-06-28 (หลังเปิด Anonymous Auth)
//
// โมเดล auth ของแอป:
//   - แอดมิน       = Firebase Auth (email+password)        → request.auth != null
//   - ครู/นักเรียน  = ล็อกอินด้วยรหัส + signInAnonymously()  → request.auth != null (anonymous)
//
// ดังนั้นทุกคนที่ใช้งานแอปจะมี request.auth != null
// → ล็อกทุก collection ให้ "ต้องล็อกอิน" ปิดช่องโหว่อ่าน/เขียนโดยไม่ล็อกอิน
//
// หมายเหตุ: เป็นการล็อกแบบหยาบ (auth != null) — ผ่านได้ทั้งแอดมิน/ครู/นักเรียน
// ฟิลเตอร์ละเอียดรายบทบาท (เช่น นักเรียนเห็นเฉพาะของตัวเอง) = เฟส 3 ทีหลัง
//   ต้องใช้ custom claims เพื่อเลี่ยง get() ใน rule (ไม่ให้เกิดค่า read เพิ่ม)
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // บัญชีค่าจ้าง + audit log
    match /sevenj_teacher_payroll/{doc} { allow read, write: if signedIn(); }
    match /sevenj_admin_payroll/{doc}   { allow read, write: if signedIn(); }
    match /auditLogs/{doc}              { allow read, write: if signedIn(); }

    // ข้อมูลหลัก — ต้องล็อกอิน (แอดมิน หรือ ครู/นักเรียน anonymous)
    match /users/{doc}        { allow read, write: if signedIn(); }
    match /packages/{doc}     { allow read, write: if signedIn(); }
    match /sessions/{doc}     { allow read, write: if signedIn(); }
    match /teacherSlots/{doc} { allow read, write: if signedIn(); }
    match /leaveRequests/{doc}{ allow read, write: if signedIn(); }
    match /settings/{doc}     { allow read, write: if signedIn(); }

    // default — collection อื่นที่ตกหล่น ก็ต้องล็อกอิน (ปิดช่องโหว่)
    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}
